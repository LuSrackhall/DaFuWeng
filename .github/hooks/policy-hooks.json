{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "python3 .github/hooks/scripts/session_context.py",
        "windows": {
          "command": "py -3 .github/hooks/scripts/session_context.py"
        },
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "python3 .github/hooks/scripts/pre_tool_policy.py",
        "windows": {
          "command": "py -3 .github/hooks/scripts/pre_tool_policy.py"
        },
        "timeout": 10
      }
    ]
  }
}
