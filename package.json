{
  "name": "da-fu-weng",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "workspaces": [
    "frontend",
    "packages/*"
  ],
  "scripts": {
    "dev:frontend": "pnpm --filter @dafuweng/frontend dev",
    "build": "pnpm -r build",
